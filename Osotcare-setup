รันบนเครื่องของคุณ 1 ครั้ง เพื่อสร้าง Rich Menu บน LINE OA

วิธีใช้:
  1. pip install requests pillow
  2. ใส่ CHANNEL_ACCESS_TOKEN ด้านล่าง
  3. วาง richmenu.png ไว้ในโฟลเดอร์เดียวกัน (หรือใช้ generate_image() สร้างเองอัตโนมัติ)
  4. python setup_richmenu.py
"""

import requests
import json
import os
from PIL import Image, ImageDraw, ImageFont

# ─── CONFIG ────────────────────────────────────────────────────────────────────
CHANNEL_ACCESS_TOKEN = "YOUR_CHANNEL_ACCESS_TOKEN_HERE"  # ใส่ token จาก LINE Developers
IMAGE_PATH = "richmenu.png"
# ────────────────────────────────────────────────────────────────────────────────

HEADERS = {
    "Authorization": f"Bearer {CHANNEL_ACCESS_TOKEN}",
    "Content-Type": "application/json"
}

# ─── Rich Menu Layout (2x3 grid, 2500x1686) ────────────────────────────────────
